{
  "name": "covergeist",
  "displayName": "Covergeist",
  "description": "Find untested code and generate tests for it — right inside your editor.",
  "version": "0.1.0",
  "publisher": "covergeist",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Testing"],
  "keywords": ["coverage", "testing", "jest", "vitest", "typescript", "ai"],
  "repository": {
    "type": "git",
    "url": "https://github.com/covergeist/covergeist"
  },
  "license": "MIT",
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "contributes": {
    "commands": [
      {
        "command": "covergeist.runScan",
        "title": "Run Coverage Scan",
        "category": "Covergeist"
      },
      {
        "command": "covergeist.signIn",
        "title": "Sign In",
        "category": "Covergeist"
      },
      {
        "command": "covergeist.signOut",
        "title": "Sign Out",
        "category": "Covergeist"
      },
      {
        "command": "covergeist.generateTest",
        "title": "Generate Test",
        "category": "Covergeist"
      }
    ],
    "configuration": {
      "title": "Covergeist",
      "properties": {
        "covergeist.apiUrl": {
          "type": "string",
          "default": "https://api.covergeist.com",
          "description": "Backend API URL. Override for local development (e.g. http://localhost:3000)."
        },
        "covergeist.clerkOAuthClientId": {
          "type": "string",
          "default": "",
          "description": "Clerk OAuth Application client_id. Create one in Clerk Dashboard → Configure → OAuth Applications."
        },
        "covergeist.clerkFrontendApiUrl": {
          "type": "string",
          "default": "",
          "description": "Clerk frontend API URL (e.g. https://your-instance.clerk.accounts.dev)."
        },
        "covergeist.billingUrl": {
          "type": "string",
          "default": "https://covergeist.com/billing",
          "description": "URL opened when the user clicks Upgrade."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "covergeist-sidebar",
          "title": "Covergeist",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "covergeist-sidebar": [
        {
          "id": "covergeist.summaryView",
          "name": "Coverage Summary"
        }
      ]
    }
  },
  "dependencies": {
    "@covergeist/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.29.0",
    "typescript": "^5.4.5"
  }
}
