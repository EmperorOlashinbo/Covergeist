# Covergeist backend environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# ------------------------------------------------------------------
# Neon (PostgreSQL)
# Get from: https://console.neon.tech → your project → Connection string
# ------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ------------------------------------------------------------------
# Clerk (auth)
# Get from: https://dashboard.clerk.com → your app → API Keys
# CLERK_JWKS_URL: Settings → API Keys → "JWKS URL" (or Domains → JWKS)
# ------------------------------------------------------------------
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# ------------------------------------------------------------------
# Stripe (billing)
# Get from: https://dashboard.stripe.com → Developers → API keys
# STRIPE_WEBHOOK_SECRET: Developers → Webhooks → your endpoint → Signing secret
# ------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# From Stripe Dashboard → Products → your subscription plan → Price ID
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override where Stripe redirects after checkout
# STRIPE_SUCCESS_URL=https://covergeist.com/billing/success
# STRIPE_CANCEL_URL=https://covergeist.com/billing/cancel

# ------------------------------------------------------------------
# Anthropic (LLM)
# Get from: https://console.anthropic.com → API Keys
# ------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# Server (optional — Railway injects PORT automatically in production)
# ------------------------------------------------------------------
PORT=3000
